# Ala-Too Digital Signatures - Environment Variables
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to version control.

# ── Database ──
POSTGRES_DB=alatoosign
POSTGRES_USER=alatoo
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── JWT ──
JWT_SECRET=CHANGE_ME_generate_at_least_64_hex_characters

# ── MinIO (S3-compatible storage) ──
MINIO_ROOT_USER=CHANGE_ME_minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
S3_ACCESS_KEY=CHANGE_ME_minio_admin
S3_SECRET_KEY=CHANGE_ME_minio_password

# ── Redis ──
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── Google OAuth2 (optional) ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Mail (optional) ──
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
